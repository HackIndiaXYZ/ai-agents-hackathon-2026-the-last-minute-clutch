# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  NyayaEval — Environment Configuration                                     ║
# ║  Copy this file to .env and fill in the values.                             ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─── Neo4j Knowledge Graph ────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nyayaeval_dev_password
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=50

# ─── Redis (Caching & LangGraph Checkpointer) ────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Adaption (Adaptive Data Platform — adaptionlabs.ai) ──────────────────────
# Get your API key: Sign in → Settings → API Keys → Create Key
ADAPTION_API_KEY=your-adaption-api-key-here
ADAPTION_API_TIMEOUT=120

# ─── LLM Provider ────────────────────────────────────────────────────────────
# Supported providers: "openai", "gemini", "groq"
# Only the API key for your chosen provider is required.
LLM_PROVIDER=gemini
OPENAI_API_KEY=
GEMINI_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=
# Model is auto-resolved per provider. Override only if needed:
#   openai  → gpt-4o           gemini → gemini-2.0-flash
#   groq    → llama-3.3-70b-versatile
LLM_MODEL_NAME=gpt-4o
LLM_TEMPERATURE=0.0

# ─── Pipeline Configuration ──────────────────────────────────────────────────
MAX_RETRIES=3
EVALUATION_FAITHFULNESS_THRESHOLD=0.85
EVALUATION_CONTEXT_RECALL_THRESHOLD=0.80
EVALUATION_LEGAL_CONSISTENCY_THRESHOLD=0.80

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── FastAPI Server ───────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
